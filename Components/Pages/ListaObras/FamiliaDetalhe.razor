@page "/obra/{ObraId:int}/familia/{FamiliaId:int}"
@rendermode InteractiveServer
@using API.SIGE.ApiServices
@using MOBILE.SIGE.Models.Caixilho
@using MOBILE.SIGE.Models.Enums
@using MOBILE.SIGE.Models.FamiliaCaixilho
@using MOBILE.SIGE.Models.Obra
@inject ObraApiService ObraApi
@inject FamiliaCaixilhoApiService FamiliaApi
@inject CaixilhoApiService CaixilhoApi
@inject NavigationManager Nav

<div class="lista-container">

    <div class="dash-header">
        <div class="dash-title">
            <button type="button"
                    style="font-size:14px;opacity:.85;background:none;border:none;color:#fff;cursor:pointer;padding:0;margin-bottom:4px"
                    @onclick="@(() => Nav.NavigateTo($"/obra/{ObraId}"))">← Obra</button>
            <h1 class="mt-1">@(_familia?.DescricaoFamilia ?? "Família")</h1>
            <p>@(_obra?.Nome ?? _familia?.NomeObra ?? "")</p>
        </div>
    </div>

    @if (_carregando)
    {
        <p style="opacity:.8">A carregar…</p>
    }
    else if (_erro != null)
    {
        <div style="color:#f88;padding:12px;border-radius:12px;background:rgba(234,50,35,.15);">@_erro</div>
    }
    else if (_familia == null)
    {
        <p>Família não encontrada.</p>
    }
    else
    {
        <div class="obra-card">
            <div class="familia-card__head">
                <div>
                    <h2 class="familia-card__title">@_familia.DescricaoFamilia</h2>
                    <p class="familia-card__meta">Obra: @(_obra?.Nome ?? _familia.NomeObra ?? $"#{_familia.IdObra}")</p>
                </div>
                <span class="@ClasseChipFamilia(_familia, _precisaFoto)">@TextoChipFamilia(_familia, _precisaFoto)</span>
            </div>

            <div class="linha-info"><span>Estado</span><span>@FormatarStatusFamilia(_familia.StatusFamilia)</span></div>
            <div class="linha-info"><span>Caixilhos</span><span>@_familia.QuantidadeCaixilhos</span></div>
            <div class="linha-info"><span>Peso total</span><span>@_familia.PesoTotalFormatado</span></div>

            @if (_precisaFoto)
            {
                <div class="familia-cta">
                    <div>
                        <strong>Esta família ainda precisa de foto de medição.</strong>
                        <p>Abra a tela de medição para tirar ou escolher a imagem no telemóvel.</p>
                    </div>
                    <button type="button"
                            class="familia-btn familia-btn--accent"
                            @onclick="@(() => Nav.NavigateTo($"/medicao/familia/{_familia.IdFamiliaCaixilho}"))">
                        Ir para medição
                    </button>
                </div>
            }
        </div>

        <section class="familia-section">
            <div class="familia-section__header">
                <h2>Caixilhos da família</h2>
                <span>@_caixilhos.Count</span>
            </div>

            @if (_caixilhos.Count == 0)
            {
                <div class="familia-empty">
                    Nenhum caixilho encontrado para esta família.
                </div>
            }
            else
            {
                <div class="caixilho-lista">
                    @foreach (var caixilho in _caixilhos)
                    {
                        <article class="caixilho-card">
                            <div class="familia-card__head">
                                <div>
                                    <h3 class="familia-card__title">@caixilho.NomeCaixilho</h3>
                                    <p class="familia-card__meta">@Dimensoes(caixilho) · Qtd. @caixilho.Quantidade</p>
                                </div>
                                <span class="@ClasseChipCaixilho(caixilho.StatusProducao)">@FormatarStatusProducao(caixilho.StatusProducao)</span>
                            </div>

                            @if (!string.IsNullOrWhiteSpace(caixilho.DescricaoCaixilho))
                            {
                                <p class="caixilho-card__desc">@caixilho.DescricaoCaixilho</p>
                            }

                            <div class="linha-info"><span>Peso unitário</span><span>@caixilho.PesoUnitario.ToString("F2") kg</span></div>

                            @if (!string.IsNullOrWhiteSpace(caixilho.Observacoes))
                            {
                                <div class="caixilho-card__obs">@caixilho.Observacoes</div>
                            }
                        </article>
                    }
                </div>
            }
        </section>
    }

    <BottomMenu />
</div>

@code {
    [Parameter] public int ObraId { get; set; }
    [Parameter] public int FamiliaId { get; set; }

    private ObraResponseDto? _obra;
    private FamiliaCaixilhoResponseDto? _familia;
    private readonly List<CaixilhoResponseDto> _caixilhos = new();
    private bool _carregando = true;
    private bool _precisaFoto;
    private string? _erro;

    protected override async Task OnParametersSetAsync()
    {
        await CarregarAsync();
    }

    private async Task CarregarAsync()
    {
        _carregando = true;
        _erro = null;
        _precisaFoto = false;
        _caixilhos.Clear();

        try
        {
            _obra = await ObraApi.GetByIdAsync(ObraId);
            _familia = await FamiliaApi.GetByIdAsync(FamiliaId);

            if (_familia == null)
                return;

            if (_familia.IdObra != ObraId)
            {
                _erro = "Esta família não pertence à obra selecionada.";
                return;
            }

            var todosCaixilhos = await CaixilhoApi.GetAllAsync() ?? new List<CaixilhoResponseDto>();
            _caixilhos.AddRange(todosCaixilhos
                .Where(c => c.IdFamiliaCaixilho == FamiliaId)
                .OrderBy(c => c.NomeCaixilho, StringComparer.OrdinalIgnoreCase));

            _precisaFoto = PrecisaFoto(_familia, _caixilhos);
        }
        catch (Exception ex)
        {
            _erro = ex.Message;
            _obra = null;
            _familia = null;
            _caixilhos.Clear();
        }
        finally
        {
            _carregando = false;
        }
    }

    private static bool PrecisaFoto(FamiliaCaixilhoResponseDto familia, List<CaixilhoResponseDto> caixilhos)
    {
        if (familia.StatusFamilia == StatusFamilia.EmProducao || familia.StatusFamilia == StatusFamilia.Produzida)
            return false;

        if (caixilhos.Count == 0)
            return false;

        return caixilhos.Any(c => c.StatusProducao != StatusProducao.Medido);
    }

    private static string Dimensoes(CaixilhoResponseDto caixilho) => $"{caixilho.Largura} x {caixilho.Altura}";

    private static string FormatarStatusFamilia(StatusFamilia status) => status switch
    {
        StatusFamilia.Pendente => "Pendente",
        StatusFamilia.EmMedicao => "Em medição",
        StatusFamilia.Medida => "Medida",
        StatusFamilia.EmProducao => "Em produção",
        StatusFamilia.Produzida => "Produzida",
        _ => status.ToString()
    };

    private static string FormatarStatusProducao(StatusProducao status) => status switch
    {
        StatusProducao.Pendente => "Pendente",
        StatusProducao.ParaMedir => "Para medir",
        StatusProducao.Medido => "Medido",
        StatusProducao.Concluido => "Concluído",
        StatusProducao.PendenteLegado => "Pendente legado",
        _ => status.ToString()
    };

    private static string TextoChipFamilia(FamiliaCaixilhoResponseDto familia, bool precisaFoto)
    {
        if (precisaFoto)
            return "Precisa de foto";

        return familia.StatusFamilia switch
        {
            StatusFamilia.EmProducao => "Em produção",
            StatusFamilia.Produzida => "Produzida",
            StatusFamilia.Medida => "Medida",
            _ => "Acompanhar"
        };
    }

    private static string ClasseChipFamilia(FamiliaCaixilhoResponseDto familia, bool precisaFoto)
    {
        if (precisaFoto)
            return "familia-chip familia-chip--warn";

        return familia.StatusFamilia switch
        {
            StatusFamilia.EmProducao => "familia-chip familia-chip--info",
            StatusFamilia.Produzida => "familia-chip familia-chip--ok",
            StatusFamilia.Medida => "familia-chip familia-chip--ok",
            _ => "familia-chip"
        };
    }

    private static string ClasseChipCaixilho(StatusProducao status) => status switch
    {
        StatusProducao.Medido => "familia-chip familia-chip--ok",
        StatusProducao.Concluido => "familia-chip familia-chip--ok",
        StatusProducao.ParaMedir => "familia-chip familia-chip--warn",
        _ => "familia-chip"
    };
}
