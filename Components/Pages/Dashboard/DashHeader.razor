<div class="dash-header">
    <div class="dash-title">
        <h1>@Titulo</h1>
        <p>@Subtitulo</p>
    </div>

    <div class="user">
        <UserAvatarLetter Nome="@NomeUsuario" />
        @if (string.IsNullOrWhiteSpace(NomeUsuario))
        {
            <span class="user-name user-name--muted">Sessão</span>
        }
        else
        {
            <span class="user-name">@NomeUsuario</span>
        }
    </div>
</div>

@code {
    [Parameter] public string Titulo { get; set; } = "Dashboard";
    [Parameter] public string Subtitulo { get; set; } = "Visão geral das obras";
    [Parameter] public string NomeUsuario { get; set; } = "";
}
