@page "/dashboard"
@using MOBILE.SIGE.Interfaces
@using MOBILE.SIGE.Models.Dashboard
@using MOBILE.SIGE.Models.Notificacao
@using MOBILE.SIGE.Models.Enums
@using MOBILE.SIGE.Models.Obra
@using API.SIGE.ApiServices
@using MOBILE.SIGE.ApiServices
@using Microsoft.AspNetCore.Components.Authorization
@using System.Security.Claims
@inject IAuthService AuthService
@inject NavigationManager Nav
@inject DashboardApiService DashboardService
@inject NotificacaoApiService NotificacaoService
@inject ObraApiService ObraService
@inject AuthenticationStateProvider AuthStateProvider

<div class="dashboard">

    <DashHeader Titulo="Dashboard"
                Subtitulo="Visão geral das obras"
                NomeUsuario="@nomeUsuario" />

    @if (loading)
    {
        <p>Carregando...</p>
    }
    else if (erro is not null)
    {
        <div style="color: red; padding: 1rem;">
            <p><strong>Erro ao carregar dados:</strong></p>
            <p>@erro</p>
        </div>
    }
    else
    {
        <div class="cards">
            <DashCard CorCss="blue"
                      IconeUrl="Icons/Bill.svg"
                      Valor="@(metricas?.TotalObras.ToString() ?? "0")"
                      Label="Total de obras" />
            <DashCard CorCss="yellow"
                      IconeUrl="Icons/Services.svg"
                      Valor="@(metricas?.ObrasEmAndamento.ToString() ?? "0")"
                      Label="Em andamento" />
            <DashCard CorCss="red"
                      IconeUrl="Icons/Medium Risk.svg"
                      Valor="@(metricas?.TotalProducoes.ToString() ?? "0")"
                      Label="Produções" />
            <DashCard CorCss="green"
                      IconeUrl="Icons/Check Mark.svg"
                      Valor="@(totalConcluidas.ToString())"
                      Label="Concluídas" />
        </div>

        <MetaMensal Titulo="Meta Mensal"
                    Descricao="@metaDescricao"
                    Percentual="@metaPercentual" />

        <AlertasList>
            @foreach (var n in notificacoes)
            {
                <AlertaItem Texto="@n.Mensagem"
                            Tipo="@n.TipoNotificacao"
                            Lida="@n.Lida" />
            }
        </AlertasList>

        <ObrasList>
            @foreach (var obra in metricas?.ObrasProgresso ?? new())
            {
                <ObraItem Nome="@($"#{obra.IdObra} - {obra.Nome}")"
                          Status="@obra.StatusObra"
                          Percentual="@obra.PercentualProducao" />
            }
        </ObrasList>
    }


</div>

@code {
    private DashboardMetricasDto? metricas;
    private List<NotificacaoResponseDto> notificacoes = new();
    private string nomeUsuario = "";
    private int idUsuario;
    private bool loading = true;
    private string? erro;

    private int totalConcluidas =>
        metricas?.ObrasProgresso?.Count(o => o.StatusObra == StatusObra.Concluida) ?? 0;

    private string metaDescricao = "0 / 0 Kg";
    private int metaPercentual;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;

        try
        {
            await CarregarUsuario();
            await CarregarDados();
        }
        catch (Exception ex)
        {
            erro = ex.Message;
            Console.WriteLine($"[Dashboard] Erro: {ex}");
        }
        finally
        {
            loading = false;
            StateHasChanged();
        }
    }

    private async Task CarregarUsuario()
    {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        var user = authState.User;

        nomeUsuario = user.FindFirst("unique_name")?.Value
                   ?? user.FindFirst(ClaimTypes.Name)?.Value
                   ?? "Usuário";

        var idClaim = user.FindFirst("nameid")?.Value
                   ?? user.FindFirst(ClaimTypes.NameIdentifier)?.Value;

        if (int.TryParse(idClaim, out var id))
            idUsuario = id;

        var cargo = user.FindFirst("role")?.Value
                 ?? user.FindFirst(ClaimTypes.Role)?.Value;

        if (!string.IsNullOrEmpty(cargo))
            nomeUsuario += $" - {cargo}";
    }

    private async Task CarregarDados()
    {
        var tarefaMetricas = DashboardService.GetMetricasAsync();
        var tarefaNotificacoes = idUsuario > 0
            ? NotificacaoService.GetByUsuarioAsync(idUsuario)
            : Task.FromResult<List<NotificacaoResponseDto>?>(new());
        var tarefaObras = ObraService.GetAllAsync();

        await Task.WhenAll(tarefaMetricas, tarefaNotificacoes, tarefaObras);

        metricas = await tarefaMetricas;
        notificacoes = (await tarefaNotificacoes) ?? new();

        var obras = (await tarefaObras) ?? new();
        CalcularMeta(obras);
    }

    private void CalcularMeta(List<ObraResponseDto> obras)
    {
        var pesoTotal = obras.Sum(o => o.PesoFinal);
        var pesoProduzido = obras.Sum(o => o.PesoProduzido);

        metaPercentual = pesoTotal > 0
            ? (int)Math.Round(pesoProduzido / pesoTotal * 100)
            : 0;

        metaDescricao = $"{pesoProduzido:N2} / {pesoTotal:N2} Kg";
    }

    private async Task Logout()
    {
        await AuthService.LogoutAsync();
        Nav.NavigateTo("/login");
    }
}
