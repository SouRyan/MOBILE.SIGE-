@inherits LayoutComponentBase
@inject IAuthService AuthService
@inject NavigationManager Nav
@using MOBILE.SIGE.Interfaces
@implements IDisposable


<div class="page">
    <main>
        <article class="content app-shell">
            @if (_loading)
            {
                <p>Carregando...</p>
            }
            else
            {
                @Body
            }
        </article>
    </main>
    @if (!_loading && _showMenu)
    {
        <NotificacaoPushWatcher />
    }
    @if (!_loading && _showMenu)
    {
        <nav class="menu" aria-label="Navegação principal">
            <NavLink href="/dashboard" class="menu-item" ActiveClass="active" title="Início">
                <img src="Icons/Analytics.svg" class="card-icon" alt="" />
            </NavLink>
            <NavLink href="/obras" class="menu-item" ActiveClass="active" title="Obras">
                <img src="Icons/Roadblock.svg" class="card-icon" alt="" />
            </NavLink>
            <NavLink href="/medicao" class="menu-item" ActiveClass="active" title="Medição">
                <img src="Icons/Wrench.svg" class="card-icon" alt="" />
            </NavLink>
            <NavLink href="/producao" class="menu-item" ActiveClass="active" title="Produção">
                <img src="Icons/Services.svg" class="card-icon" alt="" />
            </NavLink>
            <NavLink href="/conta" class="menu-item" ActiveClass="active" title="Conta">
                <img src="Icons/Email.svg" class="card-icon" alt="" />
            </NavLink>
        </nav>
    }
</div>

<div id="blazor-error-ui" data-nosnippet>
    An unhandled error has occurred.
    <a href="." class="reload">Reload</a>
    <span class="dismiss">🗙</span>
</div>



@code {
    private bool _loading = true;
    private bool _showMenu;

    protected override void OnInitialized()
    {
        Nav.LocationChanged += OnLocationChanged;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await CheckAuthAsync();
        }
    }

    private async void OnLocationChanged(object? sender, LocationChangedEventArgs e)
    {
        await InvokeAsync(CheckAuthAsync);
    }

    private async Task CheckAuthAsync()
    {
        try
        {
            var isAuthenticated = await AuthService.IsAuthenticatedAsync();
            _loading = false;
            _showMenu = isAuthenticated && !IsLoginPage() && !IsRecuperarSenhaPage() && !IsCodigoPage();

            if (!isAuthenticated && !IsLoginPage() && !IsRecuperarSenhaPage() && !IsCodigoPage())
            {
                Nav.NavigateTo("/login");
                return;
            }

            StateHasChanged();
        }
        catch
        {
            _loading = false;
            if (!IsLoginPage() && !IsRecuperarSenhaPage() && !IsCodigoPage())
            {
                Nav.NavigateTo("/login");
            }
            else
            {
                StateHasChanged();
            }
        }
    }

    private bool IsLoginPage()
    {
        var relative = Nav.ToBaseRelativePath(Nav.Uri);
        return relative.Equals("login", StringComparison.OrdinalIgnoreCase)
            || relative.StartsWith("login/", StringComparison.OrdinalIgnoreCase)
            || relative.StartsWith("login?", StringComparison.OrdinalIgnoreCase);
    }
    private bool IsRecuperarSenhaPage()
    {
        var relative = Nav.ToBaseRelativePath(Nav.Uri);
        return relative.Equals("recuperar", StringComparison.OrdinalIgnoreCase)
            || relative.StartsWith("recuperar/", StringComparison.OrdinalIgnoreCase)
            || relative.StartsWith("recuperar?", StringComparison.OrdinalIgnoreCase);
    }
    private bool IsCodigoPage()
    {
        var relative = Nav.ToBaseRelativePath(Nav.Uri);
        return relative.Equals("codigo", StringComparison.OrdinalIgnoreCase)
            || relative.StartsWith("codigo/", StringComparison.OrdinalIgnoreCase)
            || relative.StartsWith("codigo?", StringComparison.OrdinalIgnoreCase);
    }
    public void Dispose()
    {
        Nav.LocationChanged -= OnLocationChanged;
    }
}

