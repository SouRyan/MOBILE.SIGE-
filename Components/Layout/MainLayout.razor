@inherits LayoutComponentBase
@inject IAuthService AuthService
@inject NavigationManager Nav
@using MOBILE.SIGE.Interfaces
@implements IDisposable

<div class="page">
    <main>
        <article class="content px-4">
            @if (_loading)
            {
                <p>Carregando...</p>
            }
            else
            {
                @Body
            }
        </article>
    </main>
</div>

<div id="blazor-error-ui" data-nosnippet>
    An unhandled error has occurred.
    <a href="." class="reload">Reload</a>
    <span class="dismiss">🗙</span>
</div>

@code {
    private bool _loading = true;

    protected override void OnInitialized()
    {
        Nav.LocationChanged += OnLocationChanged;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await CheckAuthAsync();
        }
    }

    private async void OnLocationChanged(object? sender, LocationChangedEventArgs e)
    {
        await InvokeAsync(CheckAuthAsync);
    }

    private async Task CheckAuthAsync()
    {
        try
        {
            var isAuthenticated = await AuthService.IsAuthenticatedAsync();
            _loading = false;

            if (!isAuthenticated && !IsLoginPage())
            {
                Nav.NavigateTo("/login");
                return;
            }

            StateHasChanged();
        }
        catch
        {
            _loading = false;
            if (!IsLoginPage())
            {
                Nav.NavigateTo("/login");
            }
            else
            {
                StateHasChanged();
            }
        }
    }

    private bool IsLoginPage()
    {
        var relative = Nav.ToBaseRelativePath(Nav.Uri);
        return relative.Equals("login", StringComparison.OrdinalIgnoreCase)
            || relative.StartsWith("login/", StringComparison.OrdinalIgnoreCase)
            || relative.StartsWith("login?", StringComparison.OrdinalIgnoreCase);
    }

    public void Dispose()
    {
        Nav.LocationChanged -= OnLocationChanged;
    }
}
